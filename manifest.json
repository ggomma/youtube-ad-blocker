{
  "manifest_version": 3,
  "name": "YouTube 광고 스킵",
  "version": "1.1.1",
  "description": "YouTube 광고를 자동으로 건너뛰고, 재생 속도를 2배 제한 없이(최대 5배) 조절합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube 광고 스킵",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
